[[operation.entry_points]]
path = "app/main.py"
role = "service-main"

[operation.commands]
install = "uv sync"
test = "uv run pytest"
run = "uv run uvicorn app.main:app --reload"
lint = "uv run ruff check"

[operation.conventions]
style = "ruff strict"
commits = "conventional-commits"

[[substance.key_dependencies]]
name = "fastapi"
why = "HTTP framework"

[[substance.key_dependencies]]
name = "sentence-transformers"
why = "embedding model loading + inference"

[[substance.key_dependencies]]
name = "uvicorn"
why = "ASGI server"

[[substance.capabilities]]
phrase = "batch text embedding via /embed endpoint"

[[substance.capabilities]]
phrase = "GPU acceleration when CUDA available"

[[substance.limitations]]
phrase = "model loaded fully into memory at startup"

[[substance.limitations]]
phrase = "no streaming output — full response per request"

